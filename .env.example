# =========================================================================
# Quick start (no keys needed — pure local mode):
#   1. cp .env.example .env
#   2. Leave DEV_AUTH_BYPASS=true and AI_MOCK_RESPONSES=true (default below)
#   3. docker compose up -d        # postgres+minio
#   4. pnpm db:migrate              # creates schema + pgvector
#   5. pnpm run dev                 # http://localhost:20579
#
# When ready for real auth/AI, set the keys further down and turn off the flags.
# =========================================================================

# ---- Dev shortcuts (allow `pnpm run dev` without any external services) ----
DEV_AUTH_BYPASS=true              # Use mock dev user instead of real Clerk
AI_MOCK_RESPONSES=true            # Return canned AI responses (no API calls)

# ---- Core ----
PORT=8080
NODE_ENV=development
# Docker compose (recommended for local): postgres exposed on :5434
# (5433 is often used by other projects; we use 5434 to avoid conflicts)
DATABASE_URL=postgresql://aitutor:aitutor_dev@localhost:5434/aitutor
# Native install fallback (uncomment if running PostgreSQL on host):
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/aitutor

SESSION_SECRET=local-dev-secret-do-not-use-in-production-replace-with-32-chars

# ---- Auth provider selector ----
# One of: clerk | better-auth | bypass
# Auto-detected when unset:
#   - DEV_AUTH_BYPASS=true    → bypass
#   - BETTER_AUTH_SECRET set  → better-auth
#   - real CLERK_SECRET_KEY    → clerk
#   - otherwise               → bypass (with warning)
# AUTH_PROVIDER=better-auth

# ---- Better Auth (self-hosted, FREE, recommended for production) ----
# Set BETTER_AUTH_SECRET to a long random string (≥32 chars). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# BETTER_AUTH_SECRET=
# BETTER_AUTH_URL=http://localhost:8080
# BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:20579,http://localhost:8080

# ---- Clerk (managed; ignored when DEV_AUTH_BYPASS=true) ----
# Get from https://dashboard.clerk.com → your app → API Keys:
#   - CLERK_SECRET_KEY starts with sk_test_ or sk_live_
#   - CLERK_PUBLISHABLE_KEY starts with pk_test_ or pk_live_
# Also paste the publishable key into artifacts/learn/.env as VITE_CLERK_PUBLISHABLE_KEY
# In Clerk Dashboard → Configure → Domains, add: http://localhost:20579
CLERK_SECRET_KEY=sk_test_REPLACE_ME
CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_ME

# ---- OpenAI (ignored when AI_MOCK_RESPONSES=true) ----
AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1
AI_INTEGRATIONS_OPENAI_API_KEY=sk-REPLACE_ME

# ---- Object storage (S3-compatible; docker-compose provides MinIO) ----
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_REGION=auto
STORAGE_BUCKET=ai-tutor-uploads
STORAGE_ACCESS_KEY=aitutor
STORAGE_SECRET_KEY=aitutor_dev_secret
STORAGE_FORCE_PATH_STYLE=true
# STORAGE_PUBLIC_URL=https://cdn.example.com
