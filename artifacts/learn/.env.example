# Frontend env (Vite reads VITE_* vars at build/dev time).
#
# Quick start:
#   - Leave VITE_DEV_AUTH_BYPASS=true to skip auth for local dev.
#   - For Better Auth: set VITE_AUTH_PROVIDER=better-auth
#   - For Clerk: set VITE_DEV_AUTH_BYPASS=false and paste your
#     publishable key from https://dashboard.clerk.com.

VITE_DEV_AUTH_BYPASS=true

# Auth provider selector (one of: clerk | better-auth | bypass)
# Auto-detected if unset; matches backend AUTH_PROVIDER for dual-mode flows.
# VITE_AUTH_PROVIDER=better-auth

# Better Auth (only when VITE_AUTH_PROVIDER=better-auth)
# Defaults to current origin. Override only if backend lives on another host.
# VITE_BETTER_AUTH_URL=http://localhost:8080

# Clerk (only when VITE_AUTH_PROVIDER=clerk)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_ME
# VITE_CLERK_PROXY_URL=
