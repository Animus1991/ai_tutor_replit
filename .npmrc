auto-install-peers=false
strict-peer-dependencies=false

# Hoist packages that the bundled api-server externalizes at build time.
# Without hoisting, transitive deps live deep in .pnpm/... and aren't
# resolvable from artifacts/api-server/dist at runtime.
public-hoist-pattern[]=@aws-sdk/*
public-hoist-pattern[]=@smithy/*
public-hoist-pattern[]=@opentelemetry/*
public-hoist-pattern[]=better-auth
public-hoist-pattern[]=better-call
